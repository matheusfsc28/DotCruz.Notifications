## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if you use a multitargeting solution
# .vs/config/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# Modern Analysis results
TestResults/

# Azure IoT Edge build artifacts
.iotedge/

# Rider
.idea/
*.sln.iml

# VS Code
.vscode/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto-generated files
mono_crash.*

# Windows image-cache files
Thumbs.db
ehthumbs.db

# Folder config file
Desktop.ini

# Recycle Bin used on interactive terminals
$RECYCLE.BIN/

# NuGet Packages
*.nupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store project-specific packages
# !**/[Pp]ackages/

# BOWER Recovery Files
bower_components/

# node.js
node_modules/
npm-debug.log

# Entity Framework Core-specific files
*.design.time.cache

# BenchmarkDotNet generated artifacts
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# AspNetCore auto-generated files
.nx/

# ReSharper is a .NET coding assistant
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# JustCode is a .NET coding assistant
.JustCode

# TeamCity is a build automation system
_TeamCity*

# Omoni is a .NET unit test runner
*.omoni

# AppVeyor is a build automation system
appveyor.yml

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# Local History for Visual Studio Code
.history/

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
.DS_Store
.AppleDouble
.LSOverride
